# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Sarvam AI — get a key at https://dashboard.sarvam.ai (Settings -> API Keys).
# On day 1 also request additional credits (the assignment invites this) since
# transcription is the only credit-spending step.
SARVAM_API_KEY=

# Hugging Face write token (https://huggingface.co/settings/tokens) — only needed
# for s09 --push. You can instead `huggingface-cli login` once.
HF_TOKEN=
